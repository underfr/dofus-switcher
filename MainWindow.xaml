<Window x:Class="DofusSwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DofusSwitcher.Converters"
        Title="Dofus Switcher" Height="530" Width="680"
        Background="Transparent"
        Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:PresetIconConverter x:Key="PresetIconConv"/>

        <!-- ═══ COMBOBOX SOMBRE ═══ -->
        <!-- Style des items dans le dropdown -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCEE"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E58"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template de chaque item preset : icône + nom -->
        <DataTemplate x:Key="PresetItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Icône preset (si IconIndex >= 0) -->
                <Border Width="22" Height="22" Margin="0,0,6,0" CornerRadius="3"
                        Background="#252545" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IconIndex}" Value="-1">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Image Source="{Binding IconIndex, Converter={StaticResource PresetIconConv}}"
                           Width="18" Height="18" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                           Foreground="#CCCCEE" FontSize="12"/>
            </StackPanel>
        </DataTemplate>

        <!-- Style ComboBox sombre complet -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Background" Value="#22223C"/>
            <Setter Property="Foreground" Value="#CCCCEE"/>
            <Setter Property="BorderBrush" Value="#3A3A60"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="ItemTemplate" Value="{StaticResource PresetItemTemplate}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="Root">
                            <!-- Fond et bordure -->
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Item sélectionné -->
                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="6,0,0,0"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"/>
                                    <!-- Flèche -->
                                    <Path x:Name="Arrow" Grid.Column="1"
                                          Data="M0,0 L4,4 L8,0"
                                          Stroke="#7777AA" StrokeThickness="1.5"
                                          Fill="Transparent"
                                          Width="8" Height="5"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                    <!-- Bouton invisible qui toggle le dropdown -->
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  Focusable="False" Cursor="Hand"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <!-- Dropdown popup -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#1E1E38"
                                        BorderBrush="#5555AA" BorderThickness="1"
                                        CornerRadius="0,0,5,5"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        MaxHeight="240">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#6666BB"/>
                                <Setter TargetName="Arrow" Property="Stroke" Value="#AAAADD"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#7777CC"/>
                                <Setter TargetName="Arrow" Property="Stroke" Value="#AAAADD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton sombre -->
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3D3D60"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#5252A0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton accent (violet) -->
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#3C3C6E"/>
        </Style>

        <!-- Style bouton icône (up/down) -->
        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
        </Style>

        <!-- Style bouton activer (vert) -->
        <Style x:Key="ActivateBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#1E4A2A"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="26"/>
        </Style>

        <!-- ♂ actif = fond bleu, inactif = grisé -->
        <Style x:Key="MaleBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="Width" Value="26"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Opacity" Value="0.35"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFemale}" Value="False">
                    <Setter Property="Background" Value="#1A3A7A"/>
                    <Setter Property="Foreground" Value="#7AADFF"/>
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <!-- Grisé si mode créature actif -->
                <DataTrigger Binding="{Binding BreedIcon}" Value="True">
                    <Setter Property="Opacity" Value="0.2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ♀ actif = fond rose, inactif = grisé -->
        <Style x:Key="FemaleBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="Width" Value="26"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Opacity" Value="0.35"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFemale}" Value="True">
                    <Setter Property="Background" Value="#5A1A3A"/>
                    <Setter Property="Foreground" Value="#FF88BB"/>
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BreedIcon}" Value="True">
                    <Setter Property="Opacity" Value="0.2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Icône de classe (Segoe MDL2 Assets &#xE81E;) : actif = fond vert, inactif = grisé -->
        <Style x:Key="BreedBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="Width" Value="26"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Opacity" Value="0.45"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding BreedIcon}" Value="True">
                    <Setter Property="Background" Value="#1A4A1A"/>
                    <Setter Property="Foreground" Value="#88FF88"/>
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ SCROLLBAR SOMBRE ═══ -->
        <Style x:Key="DarkScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="bd" CornerRadius="3" Background="#3A3A60" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#5555AA"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#6666BB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar vertical -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#16162A" CornerRadius="4" Margin="2,0"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  OverridesDefaultStyle="True" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  OverridesDefaultStyle="True" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- ScrollBar horizontal -->
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="MinHeight" Value="8"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="#16162A" CornerRadius="4" Margin="0,2"/>
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                          OverridesDefaultStyle="True" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand"
                                                          OverridesDefaultStyle="True" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ BOUTONS CONTRÔLE FENÊTRE (minimize / close) ═══ -->
        <Style x:Key="WinMinBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="#8888BB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A50"/>
                                <Setter Property="Foreground" Value="#CCCCEE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinCloseBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="#8888BB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#9B1B13"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Bordure arrondie (remplace le chrome Windows) -->
    <Border Background="#1A1A2E" CornerRadius="10"
            BorderBrush="#3A3A60" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#16213E" Padding="16,10"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Icône du preset actif (masquée si aucun preset chargé) -->
                    <Image x:Name="imgActivePreset"
                           Width="24" Height="24" Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Uniform"
                           Visibility="Collapsed"/>
                    <TextBlock Text="Dofus Switcher" FontSize="17" FontWeight="Bold"
                               Foreground="#A8A8FF" VerticalAlignment="Center"/>
                    <!-- Indicateur fenêtre courante -->
                    <Border x:Name="bdCurrentWindow" Background="#1E3A1E" CornerRadius="10"
                            Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <TextBlock x:Name="tbCurrentWindow" FontSize="11" Foreground="#4CAF50"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnOverlay" Style="{StaticResource DarkBtn}"
                            Click="ToggleOverlay_Click" Margin="0,0,6,0"
                            ToolTip="Afficher / masquer l'overlay flottant"/>
                    <Button Style="{StaticResource DarkBtn}" Click="Refresh_Click" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Actualiser" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Séparateur -->
                    <Rectangle Width="1" Height="18" Fill="#333355" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <!-- Réduire -->
                    <Button Style="{StaticResource WinMinBtn}" Click="BtnMinimize_Click"
                            ToolTip="Réduire" Margin="0,0,2,0">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <!-- Fermer -->
                    <Button Style="{StaticResource WinCloseBtn}" Click="BtnClose_Click"
                            ToolTip="Fermer">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Row="1" Margin="14,10,14,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- en-têtes  -->
                <RowDefinition Height="*"/>      <!-- liste      -->
                <RowDefinition Height="Auto"/>   <!-- presets    -->
                <RowDefinition Height="Auto"/>   <!-- légende    -->
            </Grid.RowDefinitions>

            <!-- En-têtes colonnes -->
            <Grid Grid.Row="0" Margin="4,0,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Ordre"      Foreground="#666699" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="Personnage" Foreground="#666699" FontSize="11" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="2" Text="Classe"     Foreground="#666699" FontSize="11" Margin="50,0,0,0"/>
                <TextBlock Grid.Column="3" Text="Genre / Classe" Foreground="#666699" FontSize="11"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Déplacer"   Foreground="#666699" FontSize="11" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="Activer"    Foreground="#666699" FontSize="11" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Liste des fenêtres -->
            <ListView x:Name="windowsList" Grid.Row="1"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.IsVirtualizing="False"
                      SelectionMode="Single">
                <ListView.Resources>
                    <!-- Retire la sélection bleue par défaut -->
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,3"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="itemBorder"
                                            Background="#20203A"
                                            CornerRadius="7"
                                            Padding="4,5"
                                            BorderThickness="1"
                                            BorderBrush="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#1E2050"/>
                                            <Setter TargetName="itemBorder" Property="BorderBrush" Value="#5555CC"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#28285A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#28285A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.Resources>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <!-- Badge ordre de jeu -->
                            <Border Grid.Column="0" Width="34" Height="28" CornerRadius="5"
                                    Background="#2A2A55" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding PlayOrder}" FontWeight="Bold"
                                           Foreground="#A8A8FF" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Nom du personnage + indicateur actif -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="8,0">
                                <TextBlock Text="▶ " Foreground="#FFD700" FontSize="9"
                                           VerticalAlignment="Center" Margin="0,0,2,0"
                                           Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding CharacterName}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#E8E8FF" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Sprite de classe + nom de classe
                                 Si le sprite est chargé : image 42x42
                                 Sinon : fallback point coloré -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="6,0">

                                <!-- Sprite (visible si HasSprite = true) -->
                                <Border Width="42" Height="42" CornerRadius="4"
                                        Background="#16162A" Margin="0,0,6,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSprite}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Image Source="{Binding SpriteSource}"
                                           Width="40" Height="40"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Stretch="Uniform"/>
                                </Border>

                                <!-- Fallback : point coloré (visible si HasSprite = false) -->
                                <Ellipse Width="10" Height="10" Margin="0,0,7,0"
                                         VerticalAlignment="Center" Fill="{Binding ClassBrush}">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSprite}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock Text="{Binding CharacterClass}"
                                           FontSize="13" Foreground="#BBBBDD"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- ♂ / ♀ / 🐾 — genre et mode créature -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button Content="♂"
                                        Style="{StaticResource MaleBtn}"
                                        Click="SetMale_Click"
                                        ToolTip="Masculin"
                                        Margin="0,0,3,0"/>
                                <Button Content="♀"
                                        Style="{StaticResource FemaleBtn}"
                                        Click="SetFemale_Click"
                                        ToolTip="Féminin"
                                        Margin="0,0,5,0"/>
                                <Button Content="&#xE81E;"
                                        Style="{StaticResource BreedBtn}"
                                        Click="ToggleBreedIcon_Click"
                                        ToolTip="Icône de classe (remplace le portrait par le symbole de classe)"/>
                            </StackPanel>

                            <!-- Boutons Monter / Descendre -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button Content="&#xE70E;" Style="{StaticResource IconBtn}"
                                        FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        Click="MoveUp_Click" ToolTip="Monter dans l'ordre"
                                        Margin="0,0,4,0"/>
                                <Button Content="&#xE70D;" Style="{StaticResource IconBtn}"
                                        FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        Click="MoveDown_Click" ToolTip="Descendre dans l'ordre"/>
                            </StackPanel>

                            <!-- Bouton Activer maintenant -->
                            <Button Grid.Column="5" Content="&#xE768;"
                                    Style="{StaticResource ActivateBtn}"
                                    FontFamily="Segoe MDL2 Assets" FontSize="13"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Click="Activate_Click"
                                    ToolTip="Amener cette fenêtre au premier plan"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock x:Name="tbEmpty" Grid.Row="1"
                       Text="Aucune fenêtre Dofus détectée.&#x0a;Lancez le jeu puis cliquez sur Actualiser."
                       Foreground="#555577" FontSize="14" TextAlignment="Center"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <!-- ═══ BARRE PRESETS ═══ -->
            <Border Grid.Row="2" Background="#16172E" CornerRadius="7"
                    BorderBrush="#2A2A50" BorderThickness="1"
                    Padding="10,7" Margin="0,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>   <!-- label        -->
                        <ColumnDefinition Width="175"/>    <!-- ComboBox     -->
                        <ColumnDefinition Width="Auto"/>   <!-- btn Charger  -->
                        <ColumnDefinition Width="Auto"/>   <!-- btn Delete   -->
                        <ColumnDefinition Width="*"/>      <!-- spacer       -->
                        <ColumnDefinition Width="32"/>     <!-- btn icône    -->
                        <ColumnDefinition Width="148"/>    <!-- TextBox nom  -->
                        <ColumnDefinition Width="Auto"/>   <!-- btn Save     -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Preset :"
                               Foreground="#8888AA" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <!-- Sélecteur de preset existant (ComboBox stylisé) -->
                    <ComboBox x:Name="cbPresets" Grid.Column="1"
                              Style="{StaticResource DarkComboBox}"
                              SelectionChanged="CbPresets_SelectionChanged"/>

                    <Button Grid.Column="3" Content="&#xE711;"
                            Style="{StaticResource IconBtn}"
                            FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Width="Auto" Padding="7,3"
                            Click="DeletePreset_Click" Margin="4,0,0,0"
                            ToolTip="Supprimer le preset sélectionné"/>

                    <!-- Bouton aperçu icône + picker popup -->
                    <Button x:Name="btnPickIcon" Grid.Column="5"
                            Style="{StaticResource IconBtn}"
                            Width="28" Height="28"
                            Click="BtnPickIcon_Click"
                            ToolTip="Choisir une icône pour ce preset"
                            Margin="0,0,4,0">
                        <Image x:Name="imgIconPreview" Width="22" Height="22"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>

                    <!-- Popup icon picker (s'ouvre au-dessus du bouton) -->
                    <Popup x:Name="iconPickerPopup"
                           PlacementTarget="{Binding ElementName=btnPickIcon}"
                           Placement="Top"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="#1C1C34"
                                BorderBrush="#5555AA" BorderThickness="1"
                                CornerRadius="6" Padding="6">
                            <ScrollViewer MaxHeight="230"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="icIconPicker">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Width="310"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Width="36" Height="36" Margin="2"
                                                    Tag="{Binding}"
                                                    Click="IconPicker_Select"
                                                    ToolTip="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="Transparent"
                                                                CornerRadius="4" Padding="3">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#3A3A60"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#5555AA"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Image Source="{Binding Converter={StaticResource PresetIconConv}}"
                                                       Width="28" Height="28" Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Popup>

                    <!-- Champ nom du preset -->
                    <TextBox x:Name="tbPresetName" Grid.Column="6"
                             Background="#22223C" Foreground="#CCCCEE"
                             CaretBrush="White"
                             BorderBrush="#3A3A60" BorderThickness="1"
                             Padding="8,4" Height="28"
                             VerticalContentAlignment="Center"
                             FontSize="12"
                             GotFocus="TbPresetName_GotFocus"/>

                    <Button Grid.Column="7" Style="{StaticResource AccentBtn}"
                            Padding="8,4" FontSize="12"
                            Click="SavePreset_Click" Margin="6,0,0,0"
                            ToolTip="Sauvegarder l'ordre actuel sous ce nom">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sauvegarder" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Légende en bas de liste -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="4,5,4,0" Opacity="0.6">
                <TextBlock Text="▶ = fenêtre active" Foreground="#888899" FontSize="11" Margin="0,0,16,0"/>
                <TextBlock Text="Le hotkey cycle dans l'ordre de la liste" Foreground="#888899" FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- ═══ FOOTER — Configuration hotkey ═══ -->
        <Border Grid.Row="2" Background="#16213E" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Bouton afficher/changer hotkey -->
                <Button x:Name="btnHotkey" Grid.Column="0"
                        Style="{StaticResource AccentBtn}"
                        Click="ChangeHotkey_Click"
                        MinWidth="180">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="tbHotkeyBtnIcon"
                                   Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="tbHotkeyBtnText"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Statut enregistrement -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="Statut: " Foreground="#555577" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="tbHotkeyStatusIcon"
                               FontFamily="Segoe MDL2 Assets" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                    <TextBlock x:Name="tbHotkeyStatus" FontSize="12" VerticalAlignment="Center"
                               Foreground="#4CAF50" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Zone de capture de touche -->
                <Border x:Name="bdCapture" Grid.Column="3"
                        Background="#252548" CornerRadius="5"
                        BorderBrush="#5555AA" BorderThickness="1"
                        Padding="10,5" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets"
                                   Foreground="#A8A8FF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="tbCapture"
                                 Background="Transparent" Foreground="#DDDDFF"
                                 BorderThickness="0" Width="220"
                                 IsReadOnly="True" Focusable="True"
                                 Text="Appuyez sur votre combinaison..."
                                 FontSize="12" VerticalAlignment="Center"
                                 Cursor="IBeam"
                                 PreviewKeyDown="TbCapture_PreviewKeyDown"
                                 LostFocus="TbCapture_LostFocus"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>
